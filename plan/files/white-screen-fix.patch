From: Axat <axat@thompson.uz>
Date: Tue, 18 Mar 2026 18:30:00 +0500
Subject: [PATCH] fix: resolve white screen issue on 401 responses

- Add sessionStorage flag to prevent multiple redirects
- Throw error after 401 to stop code execution
- Add global error handlers in React Query
- Clear redirect flag on successful login

Fixes white screen issue after page refresh

---
 frontend/src/App.tsx              | 20 +++++++++++++++++++-
 frontend/src/lib/api-client.ts    | 11 +++++++++--
 frontend/src/pages/Login.tsx      |  2 ++
 3 files changed, 30 insertions(+), 3 deletions(-)

diff --git a/frontend/src/App.tsx b/frontend/src/App.tsx
index abc1234..def5678 100644
--- a/frontend/src/App.tsx
+++ b/frontend/src/App.tsx
@@ -22,9 +22,27 @@ import ErrorBoundary from "./components/ErrorBoundary";
 const queryClient = new QueryClient({
   defaultOptions: {
     queries: {
       retry: false,
       refetchOnWindowFocus: false,
+      onError: (error: any) => {
+        // If it's an Unauthorized error, it's already handled in api-client.ts
+        if (error?.message === 'Unauthorized') {
+          return;
+        }
+        // Log other errors for debugging
+        console.error('Query error:', error);
+      },
+    },
+    mutations: {
+      onError: (error: any) => {
+        // If it's an Unauthorized error, it's already handled in api-client.ts
+        if (error?.message === 'Unauthorized') {
+          return;
+        }
+        // Log other errors for debugging
+        console.error('Mutation error:', error);
+      },
     },
   },
 });
 
 import { store } from "./lib/store";
diff --git a/frontend/src/lib/api-client.ts b/frontend/src/lib/api-client.ts
index abc1234..def5678 100644
--- a/frontend/src/lib/api-client.ts
+++ b/frontend/src/lib/api-client.ts
@@ -20,11 +20,18 @@ export const apiFetch = async (endpoint: string, options: RequestInit = {}) =>
   });
 
   if (response.status === 401) {
+    // Prevent multiple simultaneous 401s from causing redirect loops
+    const isAlreadyRedirecting = sessionStorage.getItem('redirecting');
+    if (!isAlreadyRedirecting) {
+      sessionStorage.setItem('redirecting', 'true');
-    localStorage.removeItem("safina_token");
-    localStorage.removeItem("safina_role");
-    localStorage.removeItem("safina_user");
-    localStorage.removeItem("safina_projectId");
-    window.location.href = "/";
-    return response;
+      localStorage.removeItem("safina_token");
+      localStorage.removeItem("safina_role");
+      localStorage.removeItem("safina_user");
+      localStorage.removeItem("safina_projectId");
+      window.location.href = "/";
+    }
+    // Stop further execution by throwing an error
+    throw new Error("Unauthorized");
   }
 
   if (!response.ok) {
diff --git a/frontend/src/pages/Login.tsx b/frontend/src/pages/Login.tsx
index abc1234..def5678 100644
--- a/frontend/src/pages/Login.tsx
+++ b/frontend/src/pages/Login.tsx
@@ -21,6 +21,8 @@ const Login = () => {
 
     setIsLoading(false);
     if (success) {
+      // Clear the redirecting flag to allow future 401 redirects
+      sessionStorage.removeItem('redirecting');
       toast.success("Вход выполнен");
       navigate("/dashboard");
     } else {
